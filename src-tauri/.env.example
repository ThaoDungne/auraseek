# ──────────────────────────────────────────────────────────────────────────────
# AuraSeek – Environment Configuration Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values for your machine:
#   cp .env.example .env
#
# All values shown are the defaults. Uncomment to override.
# Loaded by: core/config.rs → AppConfig::from_env()
# ──────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# PATHS
# ═══════════════════════════════════════════════════════════════════════════════

# Main application data directory
# Linux:   ~/.local/share/auraseek
# Windows: %APPDATA%/auraseek
# macOS:   ~/Library/Application Support/auraseek
# AURASEEK_DATA_DIR=

# Log file path
# Linux:   ~/.local/share/auraseek/auraseek.log
# Windows: %APPDATA%\auraseek\auraseek.log
# macOS:   ~/Library/Logs/auraseek.log
# AURASEEK_LOG_PATH=

# Directory containing AI models, tokenizer, fonts, face_db
# Default: same as AURASEEK_DATA_DIR
# AURASEEK_MODEL_DIR=

# Path to SurrealDB binary (auto-detected if not set)
# AURASEEK_SURREAL_BIN=

# ═══════════════════════════════════════════════════════════════════════════════
# AI / MODEL TUNING
# ═══════════════════════════════════════════════════════════════════════════════

# Face recognition cosine similarity threshold (0.0 – 1.0)
# AURASEEK_FACE_THRESHOLD=0.33

# YOLO object detection confidence threshold (0.0 – 1.0)
# AURASEEK_YOLO_CONFIDENCE=0.25

# YOLO NMS IoU threshold (0.0 – 1.0)
# AURASEEK_YOLO_IOU=0.45

# Max files per ingestion batch (minimum: 1)
# AURASEEK_MAX_BATCH_SIZE=32

# ═══════════════════════════════════════════════════════════════════════════════
# RUNTIME
# ═══════════════════════════════════════════════════════════════════════════════

# AI inference device: cpu | cuda | auto
# AURASEEK_DEVICE=auto

# ONNX inference threads (default: number of CPU cores)
# AURASEEK_NUM_THREADS=

# ═══════════════════════════════════════════════════════════════════════════════
# DEBUG
# ═══════════════════════════════════════════════════════════════════════════════

# Enable debug mode: true | false
# AURASEEK_DEBUG=false
